# production-rag-lab — credentials for real generation / LLM-judged metrics.
# Copy to .env and fill values (.env is gitignored — never commit real secrets).
# Phase 0 runs fully WITHOUT any of these (extractive_mock generator + key-free metrics).
# Fill these to run configs/naive_claude.yaml and later real-LLM phases.

# ── AWS Bedrock (repo default provider for Claude) ─────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=        # only if using temporary STS creds

# ── Anthropic API (alternative to Bedrock) ────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Optional model overrides (else config/defaults apply) ─────────────────────
# BEDROCK_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
